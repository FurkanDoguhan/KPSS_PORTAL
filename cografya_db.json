  {
    "unite": "4. Türkiye'nin İklimi, Yerel Rüzgarları ve Doğal Afetler",
    "cards": [
      {
        "q": "Karasal (Step) iklimin en çok yağış aldığı mevsim ve karakteristik yağış oluşum türü hangisidir?",
        "a": "En çok yağışı **İlkbahar** mevsiminde, ısınan havanın yükselmesiyle oluşan **Konveksiyonel (Yükselim - 40ikindi)** yağışlar şeklinde alır.",
        "tag": "#"
      },
      {
        "q": "Rize'de çay ve turunçgil, Artvin'de zeytin yetişmesini sağlayan dar özel iklim alanlarına ne ad verilir?",
        "a": "Yerşekillerinin korunaklı vadi yapısı sonucu oluşan **Mikroklima** alanları denir.",
        "tag": "#"
      },
      {
        "q": "Heyelanın en çok ilkbahar mevsiminde ve Doğu Karadeniz'de görülmesinin temel sebepleri nelerdir?",
        "a": "İlkbahardaki **kar erimeleriyle toprağın suya doyması**, arazinin engebeli olması ve toprağın **killi litolojik yapısıdır**.",
        "tag": "#"
      },
      {
        "q": "Toprak erozyonunu önlemek için yamaçlarda uygulanması gereken en kritik iki tarımsal önlem nedir?",
        "a": "• Tarım alanları eğime **dik** sürülmelidir.<br>• Yamaçlarda basamaklandırma (**teraslama**) yapılmalıdır. (Nadas yerine nöbetleşe ekim yapılmalıdır).",
        "tag": "#"
      },
      {
        "q": "E-Harfi kuralına göre Türkiye'deki iklimlerin en çok yağış aldığı mevsim sırası nasıldır?",
        "a": "İç Anadolu (İlkbahar) -> Erzurum-Kars (Yaz) -> Karadeniz (Sonbahar) -> Akdeniz-Ege (Kış) şeklinde saat yönünün tersine çizilir.",
        "tag": "#"
      },
      {
        "q": "Karasal iklim bölgelerinde kuraklıktan dolayı en fazla ihtiyaç duyulan tarımsal uygulama hangisidir?",
        "a": "Toprağın bir yıl boş bırakılması olan **Nadas** uygulamasıdır. Sulamanın gelişmesiyle nadas ihtiyacı azalır.",
        "tag": "#"
      },
      {
        "q": "Kayıp Sakal şifresine göre Türkiye'yi etkileyen yerel rüzgarların saat yönündeki sırası nasıldır?",
        "a": "Kuzeybatıdan güneydoğuya: **Karayel, Yıldız, Poyraz** (Soğuk), **Samyeli, Kıble, Lodos** (Sıcak).",
        "tag": "#"
      },
      {
        "q": "Dağların zirvelerinde sıcaklığın yetersizliği nedeniyle ormanların son bulduğu sınıra ne denir ve neye bağlıdır?",
        "a": "**Orman Üst Sınırı** denir. Sıcaklığa ve enleme bağlıdır. Türkiye'de güneyden kuzeye gidildikçe orman üst sınırı alçalır.",
        "tag": "#"
      },
      {
        "q": "Akdeniz iklim bölgesinde kışın görülen yağışların oluşum kökeni nedir?",
        "a": "Sıcak ve soğuk hava kütlelerinin karşılaşmasıyla oluşan <b>Cephesel (Frontal) yağışlardır</b>. Matematik konumun sonucudur.",
        "tag": "#İklim"
      },
      {
        "q": "Türkiye'de bulutluluk oranı en yüksek ve güneşli gün sayısı en az olan iklim hangisidir?",
        "a": "<b>Karadeniz İklimi</b>'dir. Her mevsim yağışlı ve nemli olmasından dolayı bulutluluk çok fazladır.",
        "tag": "#İklim"
      },
      {
        "q": "Türkiye'de batıdan doğuya doğru sıcaklığın azalmasının temel nedeni nedir?",
        "a": "Deniz seviyesinden uzaklaşma ve <b>yükseltinin artması</b>'dır. Enlem bu durumda etkili değildir.",
        "tag": "#İklim"
      },
      {
        "q": "Türkiye'de kışın dondurucu soğuklar ve kar yağışları getiren Sibirya basıncı hangi kökenlidir?",
        "a": "<b>Termik Yüksek Basınç</b> kökenlidir. Kış aylarında çok etkilidir.",
        "tag": "#İklim"
      },
      {
        "q": "Doğu Karadeniz kıyılarında kış aylarında fön rüzgarının görülmesinin en büyük mikroklima etkisi nedir?",
        "a": "Kış ılıklığı sağlayarak <b>Turunçgil (narenciye)</b> ve çay yetiştirilmesine imkan sağlamasıdır.",
        "tag": "#İklim"
      },
      {
        "q": "Türkiye'de deprem riski en yüksek olan ve doğu-batı uzantılı fay hattı hangisidir?",
        "a": "<b>Kuzey Anadolu Fay Hattı (KAF)</b>'dır. Saros Körfezi'nden başlar, Marmara ve Karadeniz üzerinden Van Gölü'ne ulaşır.",
        "tag": "#Afet"
      },
      {
        "q": "Karadeniz Bölgesi'nde heyelanların dağ yamaçlarında set oluşturmasıyla ortaya çıkan göllere ne ad verilir?",
        "a": "<b>Heyelan Set Gölleri</b> denir. Örnek: Sera, Tortum, Abant, Yedigöller, Zinav.",
        "tag": "#Afet"
      }
