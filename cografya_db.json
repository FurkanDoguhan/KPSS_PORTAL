xt><circle cx=\"55\" cy=\"75\" r=\"7.5\" fill=\"#334155\" stroke=\"#1e293b\" stroke-width=\"1.2\" opacity=\"0.3\" /><text x=\"55\" y=\"78\" fill=\"#64748b\" font-size=\"8.5\" font-weight=\"black\" text-anchor=\"middle\" font-family=\"sans-serif\" opacity=\"0.3\">IV</text><circle cx=\"260\" cy=\"62\" r=\"7.5\" fill=\"#334155\" stroke=\"#1e293b\" stroke-width=\"1.2\" opacity=\"0.3\" /><text x=\"260\" y=\"65\" fill=\"#64748b\" font-size=\"8.5\" font-weight=\"black\" text-anchor=\"middle\" font-family=\"sans-serif\" opacity=\"0.3\">V</text></svg>\n    <button onclick=\"openMapZoomModal(this.previousElementSibling.outerHTML)\" class=\"absolute top-2 right-2 opacity-80 group-hover:opacity-100 bg-slate-950/90 hover:bg-slate-950 border border-slate-800 hover:border-slate-700 text-[9px] font-black py-1 px-2.5 rounded-lg text-emerald-400 cursor-pointer transition-all shadow hover:scale-105 flex items-center gap-1 z-10\" title=\"Haritayı Büyüt\">\n        <i class=\"fa-solid fa-magnifying-glass-plus animate-pulse\"></i> 🔍 BÜYÜT\n    </button>\n</div>\n",
        "tag": "#BuzulŞekilleri"
      },
      {
        "q": "Soru 11: Türkiye'nin yerşekilleri incelendiğinde, dağların kıyıya uzanış doğrultusunun kıyı özellikleri üzerinde belirleyici olduğu görülür. Buna göre, dağların kıyıya 'dik' uzandığı Ege kıyıları ile 'paralel' uzandığı Karadeniz kıyıları karşılaştırıldığında Ege kıyılarında aşağıdakilerden hangisinin olması 'beklenmez'?",
        "options": [
          "Kıta sahanlığının (şelf alanının) geniş olması",
          "Kıyı ile iç kesimler arasında ulaşımın geçitlerle sağlanması",
          "Koy, körfez, doğal liman ve ada sayısının fazla olması",
          "Deniz etkisinin iç kesimlere doğru kolayca sokulabilmesi"
        ],
        "correct": 1,
        "rationale": "Dağların kıyıya dik uzandığı Ege'de kıyı ile iç kesimler arasında ulaşım çok kolaydır ve geçitlere ihtiyaç yoktur. Karadeniz ve Akdeniz'de dağlar paralel uzandığı için ulaşım mecburen Zigana, Kop, Gülek, Sertavul gibi sarp geçitlerle sağlanır.<br><br><button onclick=\"showConceptOnMap('deprem')\" class=\"inline-flex items-center gap-1.5 text-[9px] sm:text-[10px] font-black py-1 px-2.5 rounded bg-emerald-500 hover:bg-emerald-400 text-slate-950 cursor-pointer transition-all shadow hover:scale-102\"><i class=\"fa-solid fa-map-location-dot animate-pulse\"></i> 🗺️ Bu Konuyu Harita Atlasında İncele</button>",
        "tag": "#HorstGraben"
      },
      {
        "q": "Soru 15: Türkiye'de karstik araziler ve yerşekilleri göz önüne alındığında, Sivas ve Çankırı çevresinde kolay eriyebilen hangi litolojik kayaç yapısı yaygındır?",
        "options": [
          "Kalker (Kireçtaşı)",
          "Jips (Alçıtaşı)",
          "Kaya Tuzu",
          "Granit"
        ],
        "correct": 1,
        "rationale": "Türkiye'de karstik arazilerin büyük kısmı Akdeniz'de kalkerdir. Ancak **Sivas, Çankırı ve İç Anadolu'nun doğusunda** jips (alçıtaşı) karstı yaygın olarak görülür.<br><br><button onclick=\"showConceptOnMap('karstik')\" class=\"inline-flex items-center gap-1.5 text-[9px] sm:text-[10px] font-black py-1 px-2.5 rounded bg-emerald-500 hover:bg-emerald-400 text-slate-950 cursor-pointer transition-all shadow hover:scale-102\"><i class=\"fa-solid fa-map-location-dot animate-pulse\"></i> 🗺️ Bu Konuyu Harita Atlasında İncele</button>",
        "tag": "#KarstikŞekiller"
      },
      {
        "q": "Soru 16: Aşağıdakilerden hangisi bir adanın kıyı oku ile karaya bağlanması sonucu oluşan ve 'Tombolo' (Bağlama Seti) olarak adlandırılan şeklin Türkiye'deki en klasik örneğidir?",
        "options": [
          "Büyükçekmece kıyıları",
          "Kapıdağ Yarımadası ve Sinop İnceburun",
          "Adana (Çukurova) Deltası",
          "Meke Maar Gölü"
        ],
        "correct": 1,
        "rationale": "Bir adanın kıyı oklarıyla karaya bağlanmasına tombolo denir. Ülkemizdeki en ünlü iki tombolo örneği **Marmara'daki Kapıdağ Yarımadası** ve **Sinop İnceburun**'dur.<br><br><button onclick=\"showConceptOnMap('kıyı')\" class=\"inline-flex items-center gap-1.5 text-[9px] sm:text-[10px] font-black py-1 px-2.5 rounded bg-emerald-500 hover:bg-emerald-400 text-slate-950 cursor-pointer transition-all shadow hover:scale-102\"><i class=\"fa-solid fa-map-location-dot animate-pulse\"></i> 🗺️ Bu Konuyu Harita Atlasında İncele</button>",
        "tag": "#TurkiyeKıyıSekilleri"
      },
      {
        "q": "Soru 17: Türkiye'nin deprem coğrafyası incelendiğinde, Marmara Saros Körfezi'nden başlayıp Karadeniz içlerinden Muş Varto'ya kadar uzanan en aktif kırık hattı hangisidir?",
        "options": [
          "Doğu Anadolu Fayı (DAF)",
          "Kuzey Anadolu Fayı (KAF)",
          "Batı Anadolu Fayı (BAF)",
          "Tuz Gölü Fay Hattı"
        ],
        "correct": 1,
        "rationale": "Marmara'dan başlayıp doğuya doğru uzanan, Türkiye'nin en uzun, aktif ve yıkıcı deprem üreten kırık hattı **Kuzey Anadolu Fayı (KAF)**'dır.<br><br><button onclick=\"showConceptOnMap('deprem')\" class=\"inline-flex items-center gap-1.5 text-[9px] sm:text-[10px] font-black py-1 px-2.5 rounded bg-emerald-500 hover:bg-emerald-400 text-slate-950 cursor-pointer transition-all shadow hover:scale-102\"><i class=\"fa-solid fa-map-location-dot animate-pulse\"></i> 🗺️ Bu Konuyu Harita Atlasında İncele</button>",
        "tag": "#TektonikDepremler"
      },
      {
        "q": "Soru 20: Antalya (Teke) ve Mersin (Taşeli) Platolarında, iklim koşullarının ılıman Akdeniz iklimi olmasına ve tarımsal faaliyetler için sıcaklığın yeterli olmasına rağmen, tarımsal verimliliğin ve nüfus yoğunluğunun son derece düşük olmasının temel nedeni nedir?",
        "options": [
          "Arazinin kolay eriyebilen karstik (kalker) yapıda olması ve suyun hızla yer altına sızması",
          "Bölgede yıllık yağış miktarının İç Anadolu'dan daha az olması",
          "Sanayi tesislerinin tarım alanlarını kirletmesi",
          "Bölgede kıl keçisi hayvancılığının yasaklanmış olması"
        ],
        "correct": 0,
        "rationale": "Antalya (Teke) ve Mersin (Taşeli) platoları kolay eriyebilen **karstik (kalker)** yapıya sahiptir. Yağan yağmur suları yüzeyde durmayıp hızla yer altına sızar, bu yüzden yüzey suları yönünden fakirdir ve tarım çok zordur.<br><br><button onclick=\"showConceptOnMap('karstik')\" class=\"inline-flex items-center gap-1.5 text-[9px] sm:text-[10px] font-black py-1 px-2.5 rounded bg-emerald-500 hover:bg-emerald-400 text-slate-950 cursor-pointer transition-all shadow hover:scale-102\"><i class=\"fa-solid fa-map-location-dot animate-pulse\"></i> 🗺️ Bu Konuyu Harita Atlasında İncele</button>",
        "tag": "#KarstikŞekiller"
      },
      {
        "q": "Soru 21: Tortul tabakaların yan basınçlara uğrayarak kıvrılması sonucunda yüksekte kalan kubbe şeklindeki kısımlara antiklinal, alçakta kalan çanak şeklindeki kısımlara ise senklinal adı verilir.<br>Buna göre, aşağıdakilerden hangisi antiklinal yapıya sahip kıvrımlı dağlarımızdan biridir?",
        "options": [
          "Aydın Dağları",
          "Kaçkar Dağları",
          "Yunt Dağları",
          "Muğla (Menteşe) Dağları"
        ],
        "correct": 1,
        "rationale": "Kaçkar Dağları (Kuzey Anadolu Dağları), Alp-Himalaya orojenezine dahil olan kıvrımlı bir antiklinal sistemdir. Aydın, Yunt ve Muğla (Menteşe) ise kırıklı orojenezle oluşan Horst alanlarıdır.",
        "tag": "#KıvrımlıDağlar"
      },
      {
        "q": "Soru 22: Türkiye'de platolar geniş yer kaplar. İç Anadolu Bölgesi'ndeki platolar genellikle hafif dalgalı düzlükler olup tahıl tarımı ve küçükbaş hayvancılığın en yoğun yapıldığı sahalardır.<br>Aşağıdakilerden hangisi bu tanıma uyan İç Anadolu platolarımızdan biri <b>değildir</b>?",
        "options": [
          "Cihanbeyli Platosu",
          "Haymana Platosu",
          "Bozok Platosu",
          "Antalya (Teke) Platosu"
        ],
        "correct": 3,
        "rationale": "Antalya (Teke) Platosu Akdeniz Bölgesi'nde yer alan karstik bir platodur. Cihanbeyli, Haymana ve Bozok ise İç Anadolu'daki yatay duruşlu (taban arazi) platolardır.",
        "tag": "#Platolarımız"
      },
      {
        "q": "Soru 23: Doğu Anadolu Bölgesi'nde yer alan Nemrut, Süphan, Tendürek ve Ağrı volkan dağlarının kuzeydoğu-güneybatı doğrultusunda düz bir çizgi halinde uzanmasının temel nedeni hangisidir?",
        "options": [
          "Bölgedeki iklim koşullarının benzer olması",
          "Bu dağların aynı jeolojik zamanda aşınması",
          "Lavların belirli bir kırık (fay) hattı boyunca yeryüzüne çıkması",
          "Akarsuların bu doğrultuda aşındırma yapması"
