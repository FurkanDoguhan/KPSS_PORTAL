-width=\"1.5\" /></g>\n  <!-- Siyasi Kara Sınırları Çizgileri -->\n  <g stroke=\"#6366f1\" stroke-width=\"1.2\" stroke-dasharray=\"3 2\" opacity=\"0.8\" fill=\"none\">\n    <path d=\"M 35,78 L 32,50\" />\n    <path d=\"M 32,50 L 70,45\" />\n    <path d=\"M 415,60 L 440,70\" />\n    <path d=\"M 440,70 L 480,90\" />\n    <path d=\"M 480,90 L 460,115 L 470,135 L 460,155\" />\n    <path d=\"M 460,155 L 415,168\" />\n    <path d=\"M 415,168 L 350,165 L 290,165 L 265,170 L 260,185\" />\n  </g>\n  \n  <!-- Komşu Ülke İsim Etiketleri -->\n  <g id=\"neighbor-labels\" opacity=\"0.45\" pointer-events=\"none\" font-family=\"sans-serif\" font-weight=\"900\" font-size=\"5.5\" fill=\"#94a3b8\">\n    <text x=\"12\" y=\"66\" text-anchor=\"middle\">YUNANİSTAN</text>\n    <text x=\"36\" y=\"38\" text-anchor=\"middle\">BULGARİSTAN</text>\n    <text x=\"442\" y=\"52\">GÜRCİSTAN</text>\n    <text x=\"475\" y=\"78\">ERMENİSTAN</text>\n    <text x=\"480\" y=\"125\">İRAN</text>\n    <text x=\"432\" y=\"180\">IRAK</text>\n    <text x=\"310\" y=\"188\">SURİYE</text>\n  </g>\n\n      <text x=\"250\" y=\"35\" fill=\"#ec4899\" font-size=\"9\" font-weight=\"black\" text-anchor=\"middle\" font-family=\"sans-serif\">SINIR KOMŞULARI VE EN UZUN SINIRIMIZ 🚪</text>\n      <text x=\"20\" y=\"70\" fill=\"#f472b6\" font-size=\"6.5\" font-weight=\"bold\" font-family=\"sans-serif\">Yunanistan &amp; Bulgaristan</text>\n      <text x=\"430\" y=\"60\" fill=\"#f472b6\" font-size=\"6.5\" font-weight=\"bold\" font-family=\"sans-serif\">Gürcistan &amp; Ermenistan</text>\n      <text x=\"440\" y=\"170\" fill=\"#f472b6\" font-size=\"6.5\" font-weight=\"bold\" font-family=\"sans-serif\">İran &amp; Irak</text>\n      <text x=\"310\" y=\"180\" fill=\"#f43f5e\" font-size=\"7.5\" font-weight=\"black\" text-anchor=\"middle\" font-family=\"sans-serif\">Suriye (En Uzun Kara Sınırımız - 911 km)</text>\n    <circle cx=\"100\" cy=\"160\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"170\" cy=\"170\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"230\" cy=\"155\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"390\" cy=\"85\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"260\" cy=\"62\" r=\"7\" fill=\"#10b981\" stroke=\"#ffffff\" stroke-width=\"1.5\" /><text x=\"260\" y=\"51\" fill=\"#ffffff\" font-size=\"8.5\" font-weight=\"black\" font-family=\"sans-serif\" text-anchor=\"middle\" background-color=\"#0f172a\" filter=\"drop-shadow(0px 1px 3px rgba(0,0,0,0.9))\">Sinop</text><circle cx=\"75\" cy=\"55\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"50\" cy=\"155\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"205\" cy=\"115\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"450\" cy=\"135\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"115\" cy=\"65\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"295\" cy=\"70\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"85\" cy=\"172\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"45\" cy=\"115\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"270\" cy=\"125\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"430\" cy=\"85\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"55\" cy=\"75\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"195\" cy=\"65\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"360\" cy=\"155\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"330\" cy=\"110\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"260\" cy=\"165\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /></svg>\n    <button onclick=\"openNoteZoomModal('SınırKomşuları')\" class=\"absolute top-2 right-2 opacity-80 group-hover:opacity-100 bg-slate-950/90 hover:bg-slate-950 border border-slate-800 hover:border-slate-700 text-[9px] font-black py-1 px-2.5 rounded-lg text-emerald-400 cursor-pointer transition-all shadow hover:scale-105 flex items-center gap-1 z-10\" title=\"Ders Notunu Tam Ekran Oku\">\n        <i class=\"fa-solid fa-expand animate-pulse\"></i> 🔍 TAM EKRAN OKU\n    </button>\n</div>\n<br><b>TÜRKİYE'NİN SINIRLARI VE SINIR KAPILARI</b><br><b>1. Sınırlarımız:</b> En uzun kara sınırımız Suriye, en kısa kara sınırımız Nahçıvan (Azerbaycan) iledir. En eski kara sınırımız Kasr-ı Şirin Antlaşması (1639) ile çizilen İran sınırıdır.<br><b>2. Sınır Kapılarımız:</b> Yunanistan (İpsala), Bulgaristan (Kapıkule - en işlek gümrük kapımız), Gürcistan (Sarp), Irak (Habur - en yüksek ihracat hacimli kapımız), İran (Gürbulak).<br>⚠️ <b>ÖSYM UYARISI:</b> Sınır kapılarından demiryolu bağlantısı olanlar: Bulgaristan (Kapıkule), Yunanistan (Uzunköprü), Suriye (Nusaybin/Çobanbey), Gürcistan (Canbaz), İran (Kapıköy). Irak ve Nahçıvan ile demiryolu bağlantısı yoktur.<br><button onclick=\"showConceptOnMap('kıyı')\" class=\"inline-flex items-center gap-1.5 text-[9px] sm:text-[10px] font-black py-1 px-2.5 rounded bg-emerald-500 hover:bg-emerald-400 text-slate-950 cursor-pointer transition-all shadow hover:scale-102\"><i class=\"fa-solid fa-map-location-dot animate-pulse\"></i> 🗺️ Bu Konuyu Harita Atlasında İncele</button>",
      "UlusalSaat": "\n<div class=\"relative group my-3 mx-auto w-full max-w-[360px]\">\n    <svg class=\"w-full h-auto shadow-lg rounded-xl border border-slate-800 bg-slate-950/60 p-2 block transition-all\" viewBox=\"0 0 500 220\" xmlns=\"http://www.w3.org/2000/svg\" id=\"inline-svg-10170556\">\n      <defs>\n        <clipPath id=\"turkey-clip-path-inline-svg-10170556\">\n          <path d=\"M 35,78 L 32,50 L 70,45 Q 95,52 115,60 L 145,62 Q 165,58 190,58 Q 225,62 260,50 Q 280,62 295,65 Q 310,60 325,66 Q 370,72 415,60 L 440,70 L 480,90 L 460,115 L 470,135 L 460,155 L 415,168 L 350,165 L 290,165 L 265,170 L 260,185 L 250,180 L 248,162 Q 215,155 170,176 Q 140,155 110,158 L 85,175 Q 65,150 50,150 Q 35,138 45,130 Q 32,120 40,110 Q 30,100 45,92 L 32,85 Z\" />\n        </clipPath>\n        <marker id=\"arrow-marker-blue\" viewBox=\"0 0 10 10\" refX=\"5\" refY=\"5\" markerWidth=\"6\" markerHeight=\"6\" orient=\"auto-start-reverse\">\n          <path d=\"M 0 0 L 10 5 L 0 10 z\" fill=\"#3b82f6\"/>\n        </marker>\n        <marker id=\"arrow-marker-red\" viewBox=\"0 0 10 10\" refX=\"5\" refY=\"5\" markerWidth=\"6\" markerHeight=\"6\" orient=\"auto-start-reverse\">\n          <path d=\"M 0 0 L 10 5 L 0 10 z\" fill=\"#f43f5e\"/>\n        </marker>\n        <marker id=\"arrow-marker-purple\" viewBox=\"0 0 10 10\" refX=\"5\" refY=\"5\" markerWidth=\"6\" markerHeight=\"6\" orient=\"auto-start-reverse\">\n          <path d=\"M 0 0 L 10 5 L 0 10 z\" fill=\"#818cf8\"/>\n        </marker>\n      </defs>\n    <g clip-path=\"url(#turkey-clip-path-inline-svg-10170556)\"><path d=\"M 35,78 L 32,50 L 70,45 Q 95,52 115,60 L 145,62 Q 165,58 190,58 Q 225,62 260,50 Q 280,62 295,65 Q 310,60 325,66 Q 370,72 415,60 L 440,70 L 480,90 L 460,115 L 470,135 L 460,155 L 415,168 L 350,165 L 290,165 L 265,170 L 260,185 L 250,180 L 248,162 Q 215,155 170,176 Q 140,155 110,158 L 85,175 Q 65,150 50,150 Q 35,138 45,130 Q 32,120 40,110 Q 30,100 45,92 L 32,85 Z\" fill=\"#111827\" stroke=\"#334155\" stroke-wid