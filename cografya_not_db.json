5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"295\" cy=\"70\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"85\" cy=\"172\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"45\" cy=\"115\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"270\" cy=\"125\" r=\"7\" fill=\"#10b981\" stroke=\"#ffffff\" stroke-width=\"1.5\" /><text x=\"270\" y=\"114\" fill=\"#ffffff\" font-size=\"8.5\" font-weight=\"black\" font-family=\"sans-serif\" text-anchor=\"middle\" background-color=\"#0f172a\" filter=\"drop-shadow(0px 1px 3px rgba(0,0,0,0.9))\">Konya-Ankara-Kayseri</text><circle cx=\"430\" cy=\"85\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"55\" cy=\"75\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"195\" cy=\"65\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"360\" cy=\"155\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"330\" cy=\"110\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"260\" cy=\"165\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /></svg>\n    <button onclick=\"openNoteZoomModal('TurkiyeFizikiToprakSorunlari')\" class=\"absolute top-2 right-2 opacity-80 group-hover:opacity-100 bg-slate-950/90 hover:bg-slate-950 border border-slate-800 hover:border-slate-700 text-[9px] font-black py-1 px-2.5 rounded-lg text-emerald-400 cursor-pointer transition-all shadow hover:scale-105 flex items-center gap-1 z-10\" title=\"Ders Notunu Tam Ekran Oku\">\n        <i class=\"fa-solid fa-expand animate-pulse\"></i> 🔍 TAM EKRAN OKU\n    </button>\n</div>\n<br><b>TOPRAK EROZYONU VE ALINACAK ÖNLEMLER</b><br><b>1. Erozyon:</b> Toprağın üst verimli tabakasının su ve rüzgar etkisiyle süpürülmesidir. Türkiye'de bitki örtüsünün cılızlığı, kuraklık ve engebe nedeniyle erozyon çok şiddetlidir.<br><b>2. Alınacak Önlemler:</b><br>• Tarım alanları eğime **dik** sürülmelidir (paralel sürülürse su yarığı açar).<br>• Yamaçlar basamaklandırılmalı (**teraslama** yapılmalıdır).<br>• Nadas yerine **nöbetleşe ekim** (bir yıl tahıl, bir yıl baklagil) uygulanmalıdır.<br>• **Ağaçlandırma** yapılmalı, meralar aşırı otlatılmamalıdır.<br>⚠️ <b>ÖSYM DETAYI:</b> Nadas erozyonu artırır (toprak boş ve korumasız kalır). Nöbetleşe ekim ise toprağı daima kapalı tuttuğu için erozyonu azaltır.<br><button onclick=\"showConceptOnMap('afet')\" class=\"inline-flex items-center gap-1.5 text-[9px] sm:text-[10px] font-black py-1 px-2.5 rounded bg-emerald-500 hover:bg-emerald-400 text-slate-950 cursor-pointer transition-all shadow hover:scale-102\"><i class=\"fa-solid fa-map-location-dot animate-pulse\"></i> 🗺️ Bu Konuyu Harita Atlasında İncele</button>",
