idth=\"1.5\" /></g>\n  <!-- Siyasi Kara Sınırları Çizgileri -->\n  <g stroke=\"#6366f1\" stroke-width=\"1.2\" stroke-dasharray=\"3 2\" opacity=\"0.8\" fill=\"none\">\n    <path d=\"M 35,78 L 32,50\" />\n    <path d=\"M 32,50 L 70,45\" />\n    <path d=\"M 415,60 L 440,70\" />\n    <path d=\"M 440,70 L 480,90\" />\n    <path d=\"M 480,90 L 460,115 L 470,135 L 460,155\" />\n    <path d=\"M 460,155 L 415,168\" />\n    <path d=\"M 415,168 L 350,165 L 290,165 L 265,170 L 260,185\" />\n  </g>\n  \n  <!-- Komşu Ülke İsim Etiketleri -->\n  <g id=\"neighbor-labels\" opacity=\"0.45\" pointer-events=\"none\" font-family=\"sans-serif\" font-weight=\"900\" font-size=\"5.5\" fill=\"#94a3b8\">\n    <text x=\"12\" y=\"66\" text-anchor=\"middle\">YUNANİSTAN</text>\n    <text x=\"36\" y=\"38\" text-anchor=\"middle\">BULGARİSTAN</text>\n    <text x=\"442\" y=\"52\">GÜRCİSTAN</text>\n    <text x=\"475\" y=\"78\">ERMENİSTAN</text>\n    <text x=\"480\" y=\"125\">İRAN</text>\n    <text x=\"432\" y=\"180\">IRAK</text>\n    <text x=\"310\" y=\"188\">SURİYE</text>\n  </g>\n<circle cx=\"100\" cy=\"160\" r=\"7\" fill=\"#10b981\" stroke=\"#ffffff\" stroke-width=\"1.5\" /><text x=\"100\" y=\"149\" fill=\"#ffffff\" font-size=\"8.5\" font-weight=\"black\" font-family=\"sans-serif\" text-anchor=\"middle\" background-color=\"#0f172a\" filter=\"drop-shadow(0px 1px 3px rgba(0,0,0,0.9))\">Antalya (Teke)</text><circle cx=\"170\" cy=\"170\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"230\" cy=\"155\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"390\" cy=\"85\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"260\" cy=\"62\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"75\" cy=\"55\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"50\" cy=\"155\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"205\" cy=\"115\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"450\" cy=\"135\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"115\" cy=\"65\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"295\" cy=\"70\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"85\" cy=\"172\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"45\" cy=\"115\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"270\" cy=\"125\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"430\" cy=\"85\" r=\"7\" fill=\"#10b981\" stroke=\"#ffffff\" stroke-width=\"1.5\" /><text x=\"430\" y=\"74\" fill=\"#ffffff\" font-size=\"8.5\" font-weight=\"black\" font-family=\"sans-serif\" text-anchor=\"middle\" background-color=\"#0f172a\" filter=\"drop-shadow(0px 1px 3px rgba(0,0,0,0.9))\">Erzurum-Kars</text><circle cx=\"55\" cy=\"75\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"195\" cy=\"65\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"360\" cy=\"155\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"330\" cy=\"110\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"260\" cy=\"165\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /></svg>\n    <button onclick=\"openNoteZoomModal('Platolarımız')\" class=\"absolute top-2 right-2 opacity-80 group-hover:opacity-100 bg-slate-950/90 hover:bg-slate-950 border border-slate-800 hover:border-slate-700 text-[9px] font-black py-1 px-2.5 rounded-lg text-emerald-400 cursor-pointer transition-all shadow hover:scale-105 flex items-center gap-1 z-10\" title=\"Ders Notunu Tam Ekran Oku\">\n        <i class=\"fa-solid fa-expand animate-pulse\"></i> 🔍 TAM EKRAN OKU\n    </button>\n</div>\n<br><b>TÜRKİYE'NİN PLATOLARI VE OLUŞUM TÜRLERİ</b><br>Platolar, akarsular tarafından derince yarılmış yüksek düzlüklerdir. Türkiye'nin platoları oluşum kökenlerine göre gruplandırılır:<br>• <b>1. Karstik Platolar:</b> Kolay eriyebilen kayaçlardan oluşan **Antalya (Teke) ve Mersin (Taşeli) Platolarıdır** (Akdeniz). Nüfus ve tarım çok azdır, kıl keçisi yetiştirilir.<br>• <b>2. Lav Örtüsü (Volkanik) Platoları:</b> Volkanik lavların birikmesiyle oluşan **Erzurum-Kars ve Ardahan Platolarıdır**. Yaz yağışları nedeniyle gür **Alpin Çayırlar** görülür, bu da **Büyükbaş Hayvancılığın (Sığırcılık)** gelişmesini sağlamıştır.<br>• <b>3. Aşınım Düzlüğü Platoları:</b> Çatalca-Kocaeli Platosudur. Nüfus, sanayi, ulaşım ve yerleşmenin en yoğun olduğu yerdir.<br>• <b>4. Tabaka Düzlüğü (Yatay Duruşlu) Platoları:</b> İç Anadolu ve Şanlıurfa-Mardin-Diyarbakır Anadolu'daki platolardır (Haymana, Cihanbeyli, Obruk, Bozok, Uzunyayla, Gaziantep, Şanlıurfa). Tahıl tarımı ve küçükbaş hayvancılık yaygındır.<br>⚠️ <b>ÖSYM DETAYI:</b> Erzurum-Kars platosunda yaz yağışlarının gür otlaklar yaratması **Büyükbaş Mera Hayvancılığını** zorunlu kılmıştır. Çatalca-Kocaeli platosunun yüksekliği en az olmasına rağmen sanayiden dolayı nüfusu en fazladır.<br><button onclick=\"showConceptOnMap('delta')\" class=\"inline-flex items-center gap-1.5 text-[9px] sm:text-[10px] font-black py-1 px-2.5 rounded bg-emerald-500 hover:bg-emerald-400 text-slate-950 cursor-pointer transition-all shadow hover:scale-102\"><i class=\"fa-solid fa-map-location-dot animate-pulse\"></i> 🗺️ Bu Konuyu Harita Atlasında İncele</button>",
