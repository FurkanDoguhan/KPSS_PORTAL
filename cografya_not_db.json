9\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"295\" cy=\"70\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"85\" cy=\"172\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"45\" cy=\"115\" r=\"7\" fill=\"#10b981\" stroke=\"#ffffff\" stroke-width=\"1.5\" /><text x=\"45\" y=\"104\" fill=\"#ffffff\" font-size=\"8.5\" font-weight=\"black\" font-family=\"sans-serif\" text-anchor=\"middle\" background-color=\"#0f172a\" filter=\"drop-shadow(0px 1px 3px rgba(0,0,0,0.9))\">İzmir-Manisa-Aydın</text><circle cx=\"270\" cy=\"125\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"430\" cy=\"85\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"55\" cy=\"75\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"195\" cy=\"65\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"360\" cy=\"155\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"330\" cy=\"110\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /><circle cx=\"260\" cy=\"165\" r=\"3.5\" fill=\"#475569\" opacity=\"0.4\" pointer-events=\"none\" /></svg>\n    <button onclick=\"openNoteZoomModal('LodosEtkisi')\" class=\"absolute top-2 right-2 opacity-80 group-hover:opacity-100 bg-slate-950/90 hover:bg-slate-950 border border-slate-800 hover:border-slate-700 text-[9px] font-black py-1 px-2.5 rounded-lg text-emerald-400 cursor-pointer transition-all shadow hover:scale-105 flex items-center gap-1 z-10\" title=\"Ders Notunu Tam Ekran Oku\">\n        <i class=\"fa-solid fa-expand animate-pulse\"></i> 🔍 TAM EKRAN OKU\n    </button>\n</div>\n<br><b>LODOS RÜZGARI VE AFET ETKİLERİ</b><br><b>1. Tanımı:</b> Türkiye'ye güneybatı yönünden esen sıcak, nemli ve dinamik karakterli rüzgardır. Ekvator yönünden geldiği için sıcaklığı belirgin derecede artırır.<br><b>2. Olumsuz Sonuçları (Afet Etkileri):</b><br>• Kışın estiğinde dağlardaki karları aniden eriterek nehir taşkınlarına ve <b>çığ afetlerine</b> yol açar.<br>• İç bölgelerde soba zehirlenmelerine (karbonmonoksit gazının bacadan geri tepmesine) neden olur.<br>• Denizde fırtına yaratarak deniz ulaşımını felç eder.<br>⚠️ <b>ÖSYM UYARISI:</b> Lodos sıcak eserek kış ılıklığı yaratsa da, yarattığı çığ ve soba zehirlenmeleri nedeniyle en riskli rüzgarımızdır.<br><button onclick=\"showConceptOnMap('iklim')\" class=\"inline-flex items-center gap-1.5 text-[9px] sm:text-[10px] font-black py-1 px-2.5 rounded bg-emerald-500 hover:bg-emerald-400 text-slate-950 cursor-pointer transition-all shadow hover:scale-102\"><i class=\"fa-solid fa-map-location-dot animate-pulse\"></i> 🗺️ Bu Konuyu Harita Atlasında İncele</button>",
